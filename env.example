# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy this to .env and fill in your values
# NEVER commit .env to git (it's already in .gitignore)
# ─────────────────────────────────────────────────────────────────────────────

# Canvas API token
# Get it from: Canvas → Account → Settings → New Access Token
CANVAS_TOKEN=your_canvas_token_here

# Your university's Canvas URL (no trailing slash)
# Examples:
#   https://canvas.sydney.edu.au
#   https://unsw.instructure.com
#   https://canvas.instructure.com  (default)
CANVAS_URL=https://your-university.instructure.com
